{
  "name": "launcher.app.privacysafe.io",
  "version": "0.11.14",
  "license": "GPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "clean:dist": "rm -rf app/",
    "copy:settings": "mkdir -p app/constants && cp -r src/common/constants/settings.json app/constants/settings.json",
    "build": "pnpm run clean:dist && vue-tsc --noEmit && vite build && pnpm run copy:settings",
    "tests:build": "bash tests-app/compile-and-build.sh",
    "tests:build-all": "pnpm run build && pnpm run tests:build",
    "tests:run-on": "bash tests-app/run-tests-on.sh",
    "serve": "vite preview",
    "stylelint": "stylelint --config .stylelint.config.cjs 'src/**/*.{vue,scss}'",
    "stylelint:fix": "stylelint --config .stylelint.config.cjs --fix 'src/**/*.{vue,scss}'",
    "linter": "eslint -c eslint.config.js --ext .vue,.ts, src",
    "linter:fix": "eslint -c eslint.config.js --fix --ext .vue,.ts, src",
    "lint": "pnpm run linter && pnpm run stylelint"
  },
  "dependencies": {
    "@terrastruct/d2": "0.1.33",
    "@types/semver": "7.7.1",
    "@v1nt1248/3nclient-lib": "0.3.11",
    "lodash": "4.18.1",
    "pinia": "3.0.4",
    "semver": "7.7.4",
    "vue": "3.5.33",
    "vue-i18n": "^11.3.2",
    "vue-router": "5.0.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "10.0.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/vue": "8.1.0",
    "@types/jasmine": "5.1.15",
    "@types/jest": "30.0.0",
    "@types/lodash": "4.17.24",
    "@types/node": "24.12.2",
    "@typescript-eslint/eslint-plugin": "8.59.0",
    "@typescript-eslint/parser": "8.59.0",
    "@vitejs/plugin-vue": "6.0.6",
    "@vue/devtools": "8.1.1",
    "@vue/eslint-config-typescript": "14.7.0",
    "@vuedx/typescript-plugin-vue": "0.7.6",
    "eslint": "10.2.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-node": "11.1.0",
    "eslint-plugin-promise": "7.2.1",
    "eslint-plugin-vue": "10.9.0",
    "globals": "17.5.0",
    "jest": "30.3.0",
    "jest-serializer-vue": "3.1.0",
    "jest-transform-stub": "2.0.0",
    "postcss-html": "1.8.1",
    "prettier": "3.8.3",
    "sass": "1.99.0",
    "stylelint": "17.9.0",
    "stylelint-config-recommended-scss": "17.0.1",
    "stylelint-config-recommended-vue": "1.6.1",
    "stylelint-config-standard": "40.0.0",
    "stylelint-scss": "7.0.0",
    "ts-jest": "29.4.9",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.0",
    "vite": "8.0.10",
    "vite-plugin-node-polyfills": "0.26.0",
    "vite-plugin-vue-devtools": "8.1.1",
    "vue-eslint-parser": "10.4.0",
    "vue-jest": "3.0.7",
    "vue-tsc": "3.2.7"
  },
  "packageManager": "pnpm@10.32.1"
}
